<!DOCTYPE html>
<html>
<head>
  <meta charset='utf-8'>
  <title>Fleet Health Dashboard</title>
</head>
<body style='margin:0;padding:24px;font-family:"Segoe UI",Tahoma,Geneva,Verdana,sans-serif;background:#f8fafc;color:#0f172a;'>
  
  <div style='max-width:1300px;margin:0 auto;'>
    <div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;'>
      <h1 style='margin:0;font-size:24px;font-weight:700;'>Fleet Health Dashboard</h1>
      <div style='display:flex;gap:12px;font-size:13px;'>
        <div style='background:#f0fdf4;padding:6px 14px;border-radius:20px;border:1px solid #bbf7d0;color:#166534;'><b>●</b> Healthy (0-14d)</div>
        <div style='background:#fffbeb;padding:6px 14px;border-radius:20px;border:1px solid #fef3c7;color:#92400e;'><b>●</b> Warning (15d+)</div>
      </div>
    </div>

    <div style='display:flex;gap:20px;margin-bottom:24px;'>
      <div style='flex:1;background:#fff;padding:20px;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 2px rgba(0,0,0,0.05);text-align:center;'>
        <div style='font-size:12px;color:#64748b;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;'>Healthy Assets</div>
        <div id='stat-dev-ok' style='font-size:36px;font-weight:700;color:#10b981;margin-top:8px;'>-</div>
      </div>
      <div style='flex:1;background:#fff;padding:20px;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 2px rgba(0,0,0,0.05);text-align:center;'>
        <div style='font-size:12px;color:#64748b;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;'>Assets at Risk (15d+)</div>
        <div id='stat-dev-warn' style='font-size:36px;font-weight:700;color:#ef4444;margin-top:8px;'>-</div>
      </div>
      <div style='flex:1;background:#fff;padding:20px;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 2px rgba(0,0,0,0.05);text-align:center;'>
        <div style='font-size:12px;color:#64748b;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;'>Healthy Drivers</div>
        <div id='stat-usr-ok' style='font-size:36px;font-weight:700;color:#10b981;margin-top:8px;'>-</div>
      </div>
      <div style='flex:1;background:#fff;padding:20px;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 2px rgba(0,0,0,0.05);text-align:center;'>
        <div style='font-size:12px;color:#64748b;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;'>Drivers at Risk (15d+)</div>
        <div id='stat-usr-warn' style='font-size:36px;font-weight:700;color:#ef4444;margin-top:8px;'>-</div>
      </div>
    </div>

    <div style='background:#fff;padding:20px;border-radius:12px;border:1px solid #e2e8f0;box-shadow:0 1px 2px rgba(0,0,0,0.05);margin-bottom:24px;display:flex;gap:20px;align-items:flex-end;'>
      <div style='flex:1;'>
        <label style='display:block;font-size:14px;font-weight:600;margin-bottom:8px;color:#475569;'>Organization Group</label>
        <select id='group-select' style='width:100%;padding:10px 14px;border-radius:8px;border:1px solid #cbd5e1;font-size:15px;background:#fcfcfc;outline:none;' onchange='window.fetchData()'>
          <option value='all'>Loading groups...</option>
        </select>
      </div>
      <div style='flex:1;'>
        <label style='display:block;font-size:14px;font-weight:600;margin-bottom:8px;color:#475569;'>List Filter (Threshold)</label>
        <select id='status-select' style='width:100%;padding:10px 14px;border-radius:8px;border:1px solid #cbd5e1;font-size:15px;background:#fcfcfc;outline:none;' onchange='window.fetchData()'>
          <option value='-1' selected>Show All Active Entities</option>
          <option value='15'>Show Warning (15-29 Days)</option>
          <option value='30'>Show Critical (30-59 Days)</option>
          <option value='60'>Show Escalated (60+ Days)</option>
        </select>
      </div>
    </div>

    <div style='display:flex;gap:24px;'>
      <div style='flex:1;background:#fff;border-radius:12px;border:1px solid #e2e8f0;overflow:hidden;'>
        <div style='background:#f1f5f9;padding:16px 20px;border-bottom:1px solid #e2e8f0;font-weight:700;font-size:16px;color:#334155;'>Vehicles & Assets</div>
        <div id='dev-summary' style='padding:10px 20px;background:#fff8f1;font-size:13px;color:#9a3412;display:none;border-bottom:1px solid #ffedd5;'></div>
        <div id='devices-container' style='padding:0 20px;'></div>
      </div>
      <div style='flex:1;background:#fff;border-radius:12px;border:1px solid #e2e8f0;overflow:hidden;'>
        <div style='background:#f1f5f9;padding:16px 20px;border-bottom:1px solid #e2e8f0;font-weight:700;font-size:16px;color:#334155;'>Active Drivers</div>
        <div id='usr-summary' style='padding:10px 20px;background:#fff8f1;font-size:13px;color:#9a3412;display:none;border-bottom:1px solid #ffedd5;'></div>
        <div id='users-container' style='padding:0 20px;'></div>
      </div>
    </div>
  </div>

  <div id='debug-ui' style='position:fixed;bottom:0;left:0;right:0;text-align:center;'>
    <button onclick='copyDebugData()' style='background:#475569;color:#fff;border:none;padding:6px 18px;cursor:pointer;font-size:12px;border-radius:6px 6px 0 0;box-shadow:0 -2px 5px rgba(0,0,0,0.1);'>Copy Debug Data</button>
  </div>

  <script>
    var _debugData = {};
    var _groupMap = {}; 
    var MAX_RENDER = 150;

    function copyDebugData() {
      var t = document.createElement('textarea');
      t.value = JSON.stringify(_debugData, null, 2);
      document.body.appendChild(t); t.select();
      document.execCommand('copy'); document.body.removeChild(t);
      alert('Debug data copied!');
    }

    function getSoftColor(days) {
      if (days <= 14) return { bg: '#f0fdf4', text: '#166534', border: '#bbf7d0', label: 'Healthy' };
      if (days <= 29) return { bg: '#fffbeb', text: '#92400e', border: '#fef3c7', label: 'Warning' };
      if (days <= 59) return { bg: '#fef2f2', text: '#b91c1c', border: '#fecaca', label: 'Critical' };
      return { bg: '#fee2e2', text: '#7f1d1d', border: '#fca5a5', label: 'Escalated' };
    }

    function isChildOf(childId, parentId) {
      if (childId === parentId) return true;
      var current = _groupMap[childId];
      var safety = 0;
      while (current && current.parent && current.parent.id && safety < 50) {
        if (current.parent.id === parentId) return true;
        current = _groupMap[current.parent.id];
        safety++;
      }
      return false;
    }

    geotab.addin['fleet-health-hosted'] = function() {
      var apiRef;

      window.fetchData = function() {
        var selectedGroupId = document.getElementById('group-select').value;
        var threshold = parseInt(document.getElementById('status-select').value, 10);
        var devDiv = document.getElementById('devices-container');
        var usrDiv = document.getElementById('users-container');
        var devSum = document.getElementById('dev-summary');
        var usrSum = document.getElementById('usr-summary');
        
        devDiv.innerHTML = '<div style="padding:30px;text-align:center;color:#64748b;">Syncing assets...</div>';
        usrDiv.innerHTML = '<div style="padding:30px;text-align:center;color:#64748b;">Syncing drivers...</div>';
        devSum.style.display = 'none';
        usrSum.style.display = 'none';
        
        document.getElementById('stat-dev-ok').textContent = '...';
        document.getElementById('stat-dev-warn').textContent = '...';
        document.getElementById('stat-usr-ok').textContent = '...';
        document.getElementById('stat-usr-warn').textContent = '...';

        apiRef.multiCall([
          ['Get', { typeName: 'Device' }],
          ['Get', { typeName: 'DeviceStatusInfo' }],
          ['Get', { typeName: 'User', search: { isDriver: true } }]
        ], function(results) {
          try {
            var now = new Date();
            var devices = results[0];
            var statuses = results[1];
            var users = results[2]; 

            var statusMap = {};
            statuses.forEach(function(s) { statusMap[s.device.id] = s; });

            function filterEntities(list, groupField) {
              var passed = [];
              for (var i = 0; i < list.length; i++) {
                var item = list[i];
                if (item.activeTo && new Date(item.activeTo).getTime() < now.getTime()) continue;
                var inGroup = false;
                if (selectedGroupId === 'all') {
                  inGroup = true;
                } else {
                  var itemGroups = item[groupField] || [];
                  for (var j = 0; j < itemGroups.length; j++) {
                    if (isChildOf(itemGroups[j].id, selectedGroupId)) {
                      inGroup = true;
                      break;
                    }
                  }
                }
                if (inGroup) passed.push(item);
              }
              return passed;
            }

            var filteredDevs = filterEntities(devices, 'groups');
            var filteredUsrs = filterEntities(users, 'companyGroups');
            
            var devOkCount = 0, devWarnCount = 0;
            var allDevsWithDays = [];
            
            filteredDevs.forEach(function(d) {
              var st = statusMap[d.id];
              var days = 999;
              if (st && st.isDeviceCommunicating !== false) {
                days = 0;
              } else if (st && st.dateTime) {
                days = Math.floor((now.getTime() - new Date(st.dateTime).getTime()) / 86400000);
              }
              if (days <= 14) devOkCount++; else devWarnCount++;
              allDevsWithDays.push({ entity: d, days: days });
            });

            var usrOkCount = 0, usrWarnCount = 0;
            var allUsrsWithDays = [];
            
            filteredUsrs.forEach(function(u) {
              var days = u.lastAccessDate ? Math.floor((now.getTime() - new Date(u.lastAccessDate).getTime()) / 86400000) : 999;
              if (days <= 14) usrOkCount++; else usrWarnCount++;
              allUsrsWithDays.push({ entity: u, days: days });
            });

            document.getElementById('stat-dev-ok').textContent = devOkCount;
            document.getElementById('stat-dev-warn').textContent = devWarnCount;
            document.getElementById('stat-usr-ok').textContent = usrOkCount;
            document.getElementById('stat-usr-warn').textContent = usrWarnCount;

            var finalDevs = [];
            for (var i = 0; i < allDevsWithDays.length; i++) {
              if (threshold === -1 || allDevsWithDays[i].days >= threshold) finalDevs.push(allDevsWithDays[i]);
            }

            var finalUsrs = [];
            for (var i = 0; i < allUsrsWithDays.length; i++) {
              if (threshold === -1 || allUsrsWithDays[i].days >= threshold) finalUsrs.push(allUsrsWithDays[i]);
            }

            finalDevs.sort(function(a, b) { return b.days - a.days; });
            finalUsrs.sort(function(a, b) { return b.days - a.days; });

            _debugData.v1 = {
              totalActiveDevs: finalDevs.length,
              totalActiveDrivers: finalUsrs.length,
              devSample: finalDevs.slice(0, 3)
            };

            devDiv.innerHTML = '';
            usrDiv.innerHTML = '';

            if (finalDevs.length > MAX_RENDER) {
              devSum.style.display = 'block';
              devSum.textContent = 'Showing top ' + MAX_RENDER + ' of ' + finalDevs.length + ' assets.';
            }
            if (finalUsrs.length > MAX_RENDER) {
              usrSum.style.display = 'block';
              usrSum.textContent = 'Showing top ' + MAX_RENDER + ' of ' + finalUsrs.length + ' drivers.';
            }

            var renderDevs = finalDevs.slice(0, MAX_RENDER);
            var renderUsrs = finalUsrs.slice(0, MAX_RENDER);

            if (renderDevs.length === 0) devDiv.innerHTML = '<div style="padding:30px;text-align:center;color:#94a3b8;">No assets match.</div>';
            renderDevs.forEach(function(item) {
              var d = item.entity; var days = item.days;
              var colors = getSoftColor(days);
              var row = document.createElement('div');
              row.style.cssText = 'padding:16px 0;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center;';
              row.innerHTML = '<a style="color:#2563eb;text-decoration:none;font-weight:600;font-size:15px;cursor:pointer;" onclick="window.parent.location.hash=\'device,id:'+d.id+'\'">' + (d.name || d.id) + '</a>' +
                              '<span style="font-size:12px;padding:4px 12px;border-radius:20px;font-weight:600;background:'+colors.bg+';color:'+colors.text+';border:1px solid '+colors.border+';">' + (days === 0 ? 'Online' : days + 'd offline') + '</span>';
              devDiv.appendChild(row);
            });

            if (renderUsrs.length === 0) usrDiv.innerHTML = '<div style="padding:30px;text-align:center;color:#94a3b8;">No drivers match.</div>';
            renderUsrs.forEach(function(item) {
              var u = item.entity; var days = item.days;
              var colors = getSoftColor(days);
              var row = document.createElement('div');
              row.style.cssText = 'padding:16px 0;border-bottom:1px solid #f1f5f9;';
              var top = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">' +
                        '<a style="color:#2563eb;text-decoration:none;font-weight:600;font-size:15px;cursor:pointer;" onclick="window.parent.location.hash=\'user,id:'+u.id+'\'">' + (u.firstName + ' ' + (u.lastName || '')).trim() + '</a>' +
                        '<span style="font-size:12px;padding:4px 12px;border-radius:20px;font-weight:600;background:'+colors.bg+';color:'+colors.text+';border:1px solid '+colors.border+';">' + (u.lastAccessDate ? days + 'd inactive' : 'Never') + '</span></div>';
              var emailLink = days > 15 ? '<a href="mailto:'+u.name+'" style="margin-left:auto;color:#2563eb;text-decoration:underline;font-weight:500;font-size:13px;">Send Reminder</a>' : '';
              var bot = '<div style="display:flex;align-items:center;font-size:14px;color:#64748b;">' +
                        '<span style="margin-right:12px;">' + u.name + '</span> <span style="color:#cbd5e1;margin-right:12px;">•</span> <span>Driver</span>' +
                        emailLink + '</div>';
              row.innerHTML = top + bot;
              usrDiv.appendChild(row);
            });

          } catch (e) {
            devDiv.innerHTML = '<div style="color:red;padding:20px;">Render Error: ' + e.message + '</div>';
          }
        }, function(err) {
            devDiv.innerHTML = '<div style="color:red;padding:20px;">API Error: ' + err + '</div>';
        });
      };

      return {
        initialize: function(api, state, callback) {
          apiRef = api;
          api.call('Get', { typeName: 'Group' }, function(groups) {
            groups.forEach(function(g) { _groupMap[g.id] = g; });
            var select = document.getElementById('group-select');
            select.innerHTML = '<option value="all">All Groups</option>';
            groups.sort(function(a,b){ return (a.name||'').localeCompare(b.name||''); }).forEach(function(g) {
              var opt = document.createElement('option');
              opt.value = g.id; opt.textContent = g.name || g.id;
              select.appendChild(opt);
            });
            window.fetchData();
          });
          callback();
        }
      };
    };
  </script>
</body>
</html>
